{
  "manifest_version": 3,
  "name": "STRTGY Focus Timer",
  "description": "A minimalist timer for focused work sessions",
  "version": "1.0.1",
  "icons": {
    "16": "images/icon-16.png",
    "32": "images/icon-32.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  },
  "action": {
    "default_title": "Open STRTGY Focus Timer",
    "default_icon": {
      "16": "images/icon-16.png",
      "32": "images/icon-32.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "notifications",
    "storage",
    "idle",
    "sidePanel"
  ],
  "side_panel": {
    "default_path": "popup.html"
  }
}
